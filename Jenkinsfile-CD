pipeline {
    agent any

    parameters {
        string(name: 'IMAGE_TAG', defaultValue: 'latest', description: 'Docker image tag to deploy')
    }

    environment {
        REGISTRY = "mouhareb"
        NAMESPACE = "pedianephro"
        RELEASE_NAME = "pedianephro"
        KUBECONFIG = "/var/jenkins_home/.kube/config"
    }

    stages {

        stage('Checkout') {
            steps {
                git branch: 'main',
                    url: 'https://github.com/azizbenmo/Esprit-PIDEV-4SAE10-2026-PediaNephro.git'
            }
        }

        stage('Check Kubernetes Access') {
            steps {
                sh '''
                set -e
                echo "========== Testing Kubernetes access =========="
                kubectl get nodes
                kubectl get pods -A
                '''
            }
        }

        stage('Check Helm') {
            steps {
                sh '''
                set -e
                echo "========== Checking Helm =========="
                helm version
                '''
            }
        }

        stage('Deploy With Helm') {
            steps {
                sh '''
                set -e

                echo "========== Deploying PediaNephro with Helm =========="
                echo "Registry: $REGISTRY"
                echo "Image tag: $IMAGE_TAG"
                echo "Namespace: $NAMESPACE"

                helm upgrade --install $RELEASE_NAME ./helm/pedianephro \
                  --namespace $NAMESPACE \
                  --create-namespace \
                  --set image.registry=$REGISTRY \
                  --set image.tag=$IMAGE_TAG
                '''
            }
        }

        stage('Wait For Deployment') {
            steps {
                sh '''
                set -e

                echo "========== Waiting for deployments =========="

                kubectl rollout status deployment/config-server -n $NAMESPACE --timeout=180s || true
                kubectl rollout status deployment/eureka-server -n $NAMESPACE --timeout=180s || true
                kubectl rollout status deployment/gateway -n $NAMESPACE --timeout=180s || true
                kubectl rollout status deployment/dossier-medical -n $NAMESPACE --timeout=180s || true
                kubectl rollout status deployment/mysql -n $NAMESPACE --timeout=180s || true
                '''
            }
        }

        stage('Verify Deployment') {
            steps {
                sh '''
                set -e

                echo "========== Pods =========="
                kubectl get pods -n $NAMESPACE -o wide

                echo "========== Services =========="
                kubectl get services -n $NAMESPACE

                echo "========== Helm Releases =========="
                helm list -n $NAMESPACE

                echo "========== Deployment Status =========="
                kubectl get deployments -n $NAMESPACE
                '''
            }
        }
    }

    post {
        success {
            echo "CD Pipeline completed successfully. PediaNephro deployed with Helm."
        }

        failure {
            echo "CD Pipeline failed. Check Kubernetes, Helm, kubeconfig, and pod logs."
        }

        always {
            sh '''
            echo "========== Final Kubernetes status =========="
            kubectl get pods -n $NAMESPACE || true
            kubectl get svc -n $NAMESPACE || true
            '''
        }
    }
}
